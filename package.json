{
  "name": "recipe-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "server": "node --env-file-if-exists=.env server/index.js",
    "start": "node --env-file-if-exists=.env server/index.js",
    "prod": "npm run build && npm run start"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.5.0",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "groq-sdk": "^0.26.0",
    "lucide-react": "^0.511.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "playwright": "^1.60.0"
  }
}
